{
"openapi": "3.0.0",
"info": {
"title": "TodoCamisetas API",
"version": "1.0.0",
"description": "API para gestión de camisetas, clientes y tallas"
},
"servers": [
{
"url": "http://localhost:8082"
}
],
"paths": {
"/camisetas": {
"get": {
"summary": "Listar camisetas",
"responses": {
"200": {
"description": "Lista de camisetas"
}
}
},
"post": {
"summary": "Crear camiseta",
"responses": {
"201": {
"description": "Camiseta creada correctamente"
}
}
}
},
"/camisetas/{id}": {
"put": {
"summary": "Actualizar camiseta",
"parameters": [
{
"name": "id",
"in": "path",
"required": true,
"schema": {
"type": "integer"
}
}
],
"responses": {
"200": {
"description": "Camiseta actualizada correctamente"
}
}
},
"delete": {
"summary": "Eliminar camiseta",
"parameters": [
{
"name": "id",
"in": "path",
"required": true,
"schema": {
"type": "integer"
}
}
],
"responses": {
"200": {
"description": "Camiseta eliminada correctamente"
}
}
}
},
"/clientes": {
"get": {
"summary": "Listar clientes",
"responses": {
"200": {
"description": "Lista de clientes"
}
}
},
"post": {
"summary": "Crear cliente",
"responses": {
"201": {
"description": "Cliente creado correctamente"
}
}
}
},
"/clientes/{id}": {
"put": {
"summary": "Actualizar cliente",
"parameters": [
{
"name": "id",
"in": "path",
"required": true,
"schema": {
"type": "integer"
}
}
],
"responses": {
"200": {
"description": "Cliente actualizado correctamente"
}
}
},
"delete": {
"summary": "Eliminar cliente",
"parameters": [
{
"name": "id",
"in": "path",
"required": true,
"schema": {
"type": "integer"
}
}
],
"responses": {
"200": {
"description": "Cliente eliminado correctamente"
}
}
}
},
"/tallas": {
"get": {
"summary": "Listar tallas",
"responses": {
"200": {
"description": "Lista de tallas"
}
}
},
"post": {
"summary": "Crear talla",
"responses": {
"201": {
"description": "Talla creada correctamente"
}
}
}
},
"/tallas/{id}": {
"put": {
"summary": "Actualizar talla",
"parameters": [
{
"name": "id",
"in": "path",
"required": true,
"schema": {
"type": "integer"
}
}
],
"responses": {
"200": {
"description": "Talla actualizada correctamente"
}
}
},
"delete": {
"summary": "Eliminar talla",
"parameters": [
{
"name": "id",
"in": "path",
"required": true,
"schema": {
"type": "integer"
}
}
],
"responses": {
"200": {
"description": "Talla eliminada correctamente"
}
}
}
},
"/precio/{camiseta}/{cliente}": {
"get": {
"summary": "Obtener precio dinámico",
"parameters": [
{
"name": "camiseta",
"in": "path",
"required": true,
"schema": {
"type": "integer"
}
},
{
"name": "cliente",
"in": "path",
"required": true,
"schema": {
"type": "integer"
}
}
],
"responses": {
"200": {
"description": "Precio calculado correctamente"
}
}
}
}
}
}
